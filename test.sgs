@type System;
@name ClosureTest;

fn main() -> void {
    let lambda_print = |msg: string| {
        println("from closure:", msg);
    };

    lambda_print("hello world");

    let run_twice = |func: func, text: string| {
        func(text);
        func(text);
    };

    run_twice(lambda_print, "ok");
}
