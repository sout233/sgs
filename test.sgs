@type System;
@name Test;

fn main() -> void {
    let a = 100;
    println("First a:", a);

    let a = "hello shadowing";
    println("Second a:", a);

    a = "world";
    println("Third a:", a);

    {
        let a = 999;
        println("Inner a:", a);
    }

    println("Final a:", a); // world
}
