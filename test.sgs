@type System;
@name Test;

struct PlayerData {
    hp: number,
    name: string,
}

fn _main() -> void {
    let a = 100;
    println("First a:", a);

    let mut a = "hello shadowing";
    println("Second a:", a);

    a = "world";
    println("Third a:", a);

    {
        let a = 999;
        println("Inner a:", a);
    }

    println("Final a:", a); // world

    let mut a = 0;
    while a < 10 {
        println("a:", a);
        a += 1;
    }

    println("Final a:", a); // 10

    let mut stats = [100, 50, 20];

    let hp = stats[0];
    println("Initial HP:", hp);

    stats[0] -= 15;
    stats[1] += 5;

    println("After Damage - HP:", stats[0], "MP:", stats[1]);
    println("stats:", stats);

    for hp in stats {
        println("HP:", hp);
    }

    stats.pop();
    println("pop");
    stats.remove(0);
    stats.insert(1, 2);

    for hp in stats {
        stats.push(1);
        println("HP:", hp);
    }

    println("IM" ++ "GAY");
    let mut str = "what is your ";
    str ++= "name?";
    println("Final str:", str);

    let mut p = PlayerData {
        hp: 123,
        name: "Sout",
    };
    println(p.name);
    p.name = "guy";

    let num = (4);
    println("num:", num);
    println(
        p.hp,
        "HP: " ++ p.name
    );
}

@type System;
@name Test2;

struct Vector2 {
    x: float,
    y: float,
}

struct Player {
    pos: Vector2
}

fn main() -> void {
    let mut player = Player {
        pos: Vector2 { x: 0, y: 0 }
    };

    println(player);
    player.pos = just_move(player.pos);
    println(player);
}

fn just_move(pos: Vector2) -> Vector2 {
    Vector2 {
        x: pos.x + 1,
        y: pos.y + 1
    }
}
