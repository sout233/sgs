@type System;
@name Test;

fn main() -> void {
    let a = 100;
    println("First a:", a);

    let mut a = "hello shadowing";
    println("Second a:", a);

    a = "world";
    println("Third a:", a);

    {
        let a = 999;
        println("Inner a:", a);
    }

    println("Final a:", a); // world

    let mut a = 0;
    while a < 10 {
        println("a:", a);
        a += 1;
    }

    println("Final a:", a); // 10

    let mut stats = [100, 50, 20];

    let hp = stats[0];
    println("Initial HP:", hp);

    stats[0] -= 15;
    stats[1] += 5;

    println("After Damage - HP:", stats[0], "MP:", stats[1]);
    println("stats:", stats);

    for hp in stats {
        println("HP:", hp);
    }

    println("IM" ++ "GAY");
    let mut str = "what is your ";
    str ++= "name?";
    println("Final str:", str);
}
